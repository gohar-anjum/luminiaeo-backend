APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=luminiaeo_backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# DataForSEO (for keyword ideas / informational flow)
# DATAFORSEO_BASE_URL=https://api.dataforseo.com/v3
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
# DATAFORSEO_KEYWORD_PLANNER_ENABLED=false

# Keyword Intent microservice (top 100 informational keywords from DataForSEO Labs)
KEYWORD_INTENT_SERVICE_URL=http://localhost:8002
KEYWORD_INTENT_SERVICE_TIMEOUT=60
# Informational planner: reuse DB result for same seeds/options if run is newer than this many days (default 14)
INFORMATIONAL_PLANNER_DEDUP_TTL_DAYS=14

# Page Analysis microservice (meta tag optimizer, semantic score checker)
PAGE_ANALYSIS_SERVICE_URL=http://localhost:8004
PAGE_ANALYSIS_TIMEOUT=15

# Keyword clustering microservice (/cluster, /cluster-rule-based, /keyword-cluster tree)
# Use http://clustering:8001 only when Laravel/queue runs INSIDE the same docker-compose network (see compose env overrides).
# When running `php artisan` on your HOST, use the published port:
KEYWORD_CLUSTERING_SERVICE_URL=http://127.0.0.1:8001
KEYWORD_CLUSTERING_TIMEOUT=180
# KEYWORD_CLUSTER_SNAPSHOT_TTL_DAYS=7
# KEYWORD_CLUSTER_TREE_SCHEMA_VERSION=1
# TREE_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Billing (Stripe credits) – required for checkout and webhooks
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
FRONTEND_URL=http://localhost:5173
# App URL (API base) must match the host used in email verification links (APP_URL in production)
# Google Sign-In for users (separate from GOOGLE_ADS_*). Use a Web client ID; send id_token from the React app to POST /api/auth/google
# GOOGLE_OAUTH_CLIENT_ID=
# EMAIL_VERIFICATION_EXPIRE_MINUTES=60
# CORS: comma-separated origins when frontend differs (required when supports_credentials=true)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# BILLING_MIN_CREDITS=100
# BILLING_MAX_CREDITS=10000
# BILLING_CREDIT_INCREMENT=10
# BILLING_CENTS_PER_CREDIT=5

# Admin panel (optional Redis cache key overrides for precomputed dashboard data)
# ADMIN_STATS_CACHE_KEY=admin_stats_cache
# ADMIN_CHARTS_CACHE_KEY=admin_charts_cache
